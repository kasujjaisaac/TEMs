<script>
    const sectionSelect = document.getElementById('section-select');
    const sectionMenu = document.getElementById('section-menu');
    const accordionHeaders = document.querySelectorAll('.accordion-header');

    function togglePanel(button) {
        const item = button.closest('.accordion-item');
        const panel = item.querySelector('.accordion-panel');
        const indicator = button.querySelector('.accordion-indicator');
        const isOpen = panel.classList.contains('open');

        document.querySelectorAll('.accordion-panel.open').forEach(openPanel => {
            if (openPanel !== panel) {
                openPanel.classList.remove('open');
                const prev = openPanel.previousElementSibling;
                if (prev) prev.querySelector('.accordion-indicator').classList.remove('open');
            }
        });

        panel.classList.toggle('open', !isOpen);
        if (indicator) indicator.classList.toggle('open', !isOpen);
    }

    accordionHeaders.forEach(button => {
        button.addEventListener('click', () => {
            togglePanel(button);
        });
    });

    function scrollToSection(id) {
        const section = document.getElementById(id);
        if (!section) return;
        const headerButton = section.querySelector('.accordion-header');
        if (headerButton) {
            const panel = section.querySelector('.accordion-panel');
            if (!panel.classList.contains('open')) {
                togglePanel(headerButton);
            }
        }
        section.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    sectionSelect.addEventListener('change', (event) => {
        scrollToSection(event.target.value);
    });

    sectionMenu.addEventListener('change', (event) => {
        scrollToSection(event.target.value);
    });
</script>
